{
  "manifest_version": 3,
  "name": "Block Site",
  "version": "1.0",
  "description": "A Chrome extension to block websites",
  "permissions": ["storage", "declarativeNetRequest", "tabs"],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts"
  }
}