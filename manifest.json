{
  "manifest_version": 3,
  "name": "Block Addictive Site",
  "version": "1.0",
  "description": "A Chrome extension to block addictive websites",
  "permissions": ["storage", "declarativeNetRequest", "tabs"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "index.html",
    "default_icons": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts"
  }
}
